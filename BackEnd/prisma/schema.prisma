generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  UserId    String   @id @default(uuid()) @db.Uuid
  password  String
  email     String   @unique
  createdAt DateTime @default(now())
  update    DateTime @updatedAt
  fullName  String
  houses    House[]
}

model House {
  HouseId   String   @id @default(uuid()) @db.Uuid
  name      String   
  address   String?
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [UserId])
  sensors   Sensor[]
  createdAt DateTime @default(now())
  update    DateTime @updatedAt
}

model Sensor {
  SensorNumber String @id @default(uuid()) @db.Uuid
  name         String
  type         String
  status       String
  houseId      String   @db.Uuid
  house        House   @relation(fields: [houseId], references: [HouseId])
  createdAt    DateTime @default(now())
  update       DateTime @updatedAt
  eventLogs    EventLog[]
}

model EventLog {
  EventLogId   String   @id @default(uuid()) @db.Uuid
  type         String
  title        String
  details      String
  sensorId     String   @db.Uuid
  sensor       Sensor?   @relation(fields: [sensorId], references: [SensorNumber])
  createdAt    DateTime @default(now())
}